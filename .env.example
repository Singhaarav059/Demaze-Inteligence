# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored by design.

# Supabase (run history, saved research)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Scraping
FIRECRAWL_API_KEY=

# Search-grounded discovery + enrichment
TAVILY_API_KEY=
SERPER_API_KEY=

# LLM provider — NVIDIA NIM is the only provider (OpenRouter was removed
# 2026-07-18, not needed)
NVIDIA_NIM_API_KEY=
# Overrides the first/default NVIDIA NIM model. Current default (if unset):
# openai/gpt-oss-120b. Falls back to deepseek-ai/deepseek-v4-pro if it fails.
# See lib/ai/provider-factory.ts's header comment for why these two (and why
# thinkingmachines/inkling, the former default, was dropped).
NVIDIA_NIM_MODEL=

# Admin route auth
ADMIN_SECRET=

# Outbound integrations — encrypts stored provider API keys at rest
# (outbound_integrations.credential_encrypted). Generate with:
#   openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=

# Outbound provider selection fallback (used only when Supabase has no
# active row for a capability — the Integrations settings page is the
# primary way to choose a provider). One of: mock | <vendor-name>
OUTBOUND_DECISION_MAKER_DISCOVERY_PROVIDER=mock
OUTBOUND_EMAIL_FINDER_PROVIDER=mock
OUTBOUND_ENRICHMENT_PROVIDER=mock
OUTBOUND_SENDING_PROVIDER=mock
OUTBOUND_WARMUP_PROVIDER=mock

# Prospeo (Email Finder + Contact Enrichment provider) — real API key.
# Preferred path is entering this in /admin/outbound/integrations (encrypted
# at rest); this env var is a fallback used only when no DB credential is
# stored for that capability. Also select "prospeo" as the active provider
# in Outbound Integrations, or set OUTBOUND_EMAIL_FINDER_PROVIDER=prospeo /
# OUTBOUND_ENRICHMENT_PROVIDER=prospeo above.
PROSPEO_API_KEY=

# Gmail (Email Sending provider) — interim sending provider until a paid
# cold-outreach platform (Smartlead/Instantly) is chosen. Unlike Prospeo,
# this is OAuth, not a pasted API key:
#   1. Google Cloud Console -> APIs & Services -> enable "Gmail API".
#   2. OAuth consent screen -> add the gmail.send scope.
#   3. Credentials -> Create OAuth client ID (type: Web application).
#   4. Add an Authorized redirect URI matching exactly:
#      <your-app-origin>/api/admin/outbound/integrations/gmail/oauth/callback
#      (e.g. http://localhost:3000/... for local dev)
#   5. Put that Client ID/Secret below.
#   6. In /admin/outbound/integrations, select "gmail" under Email Sending
#      and click "Connect with Google" — this is a real Google consent
#      screen the account owner must click through themselves; nothing here
#      can do that step automatically.
# The resulting refresh token is stored encrypted (alongside the client
# id/secret used to obtain it) in outbound_integrations.credential_encrypted,
# same as every other vendor credential in this app.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — only needed if the app's own request origin doesn't match what
# you registered in Google Cloud Console (e.g. behind a proxy/tunnel).
GOOGLE_OAUTH_REDIRECT_URI=
