# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored by design.

# Supabase (run history, saved research)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Scraping
FIRECRAWL_API_KEY=

# Search-grounded discovery + enrichment
TAVILY_API_KEY=
SERPER_API_KEY=

# LLM provider — configure one of the two pairs below
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Admin route auth
ADMIN_SECRET=
